# Environment variables (copy to .env for local development)

NODE_ENV=development

# API
PORT=3002
CORS_ORIGIN=http://localhost:3000,http://localhost:3003
RATE_LIMIT_MAX=300

# Auth — required in production
TCM_JWT_SECRET=change-me-in-production
# TCM_USERS_JSON={"admin":{"password":"...","user":{...}}}

# Demo-only credentials (ignored when ALLOW_DEMO_AUTH=false)
ALLOW_DEMO_AUTH=true
TCM_ADMIN_PASSWORD=
TCM_PHARMACIST_PASSWORD=

# Optional rule override
# TCM_RULES_PATH=./server/config/tcm-rules.json
