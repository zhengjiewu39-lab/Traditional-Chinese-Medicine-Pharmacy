    }
    const last = customersData.growth[customersData.growth.length - 1];
    const trend = Math.round((last.鏂板鎴?+ last.鑰佸鎴? * 1.05);
    return [
      { name: '涓嬫湀', 棰勬祴瀹㈡埛: trend },
      { name: '2涓湀鍚?, 棰勬祴瀹㈡埛: Math.round(trend * 1.04) },
