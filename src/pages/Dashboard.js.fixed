  // AI棰勬祴閫昏緫
  const handleAIPredict = () => {
    // 鍋囪姣忎釜鑽潗鏈塵onthly閿€閲忔暟鎹?
    const results = (inventoryData.topProducts || []).map(prod => {
      // 闅忔満鐢熸垚杩?涓湀閿€閲?
      const monthly = prod.monthly || Array.from({ length: 6 }, () => Math.floor(Math.random() * 300) + 20);
      const avg = monthly.reduce((a, b) => a + b, 0) / monthly.length;
      const fluct = Math.max(...monthly) - Math.min(...monthly);
      const predict = Math.round(avg + fluct * 0.2);
      const suggestStock = Math.round(predict * 1.2);
      return {
        name: prod.name,
        last6: monthly,
        predict,
        suggestStock,
        current: prod.stock
      };
    });
    setAiResults(results);
    setAiPredictOpen(true);
  };

  // 娣诲姞鐩堝埄鑳藉姏鍒嗘瀽鐩稿叧鐘舵€?
  const [profitabilityData, setProfitabilityData] = useState(null);
  const [profitabilityTab, setProfitabilityTab] = useState(0);
  const [optimizationDialogOpen, setOptimizationDialogOpen] = useState(false);
  const [selectedOptimization, setSelectedOptimization] = useState(null);
  const [aiProfitSimulationOpen, setAiProfitSimulationOpen] = useState(false);
  const [profitSimulationResults, setProfitSimulationResults] = useState(null);

  // 娣诲姞鐩堝埄鑳藉姏鍒嗘瀽鐩稿叧澶勭悊鍑芥暟
  const handleProfitabilityTabChange = (event, newValue) => {
    setProfitabilityTab(newValue);
  };

  // AI鐩堝埄妯℃嫙鍒嗘瀽
  const handleRunProfitSimulation = () => {
    setAiProfitSimulationOpen(true);
    
    // 妯℃嫙AI鍒嗘瀽杩囩▼
    setTimeout(() => {
      // 鐢熸垚妯℃嫙缁撴灉鏁版嵁
      const baselineRevenue = profitabilityData.businessLines.reduce((sum, line) => sum + line.revenue, 0);
      const baselineProfit = profitabilityData.businessLines.reduce((sum, line) => sum + line.profit, 0);
      const baselineMargin = (baselineProfit / baselineRevenue * 100).toFixed(1);
      
      // 妯℃嫙涓夌绛栫暐鍦烘櫙
      const scenarios = [
        {
          name: "浜у搧缁撴瀯浼樺寲",
          description: "澧炲姞楂樻瘺鍒╀骇鍝佹瘮渚嬶紝鍑忓皯浣庢瘺鍒╀骇鍝佺嚎",
          revenueChange: 8.5,
          marginChange: 3.2,
          implementationCost: 850000,
          roi: 320,
          paybackPeriod: 4.2,
          riskLevel: "涓?,
          timeToImplement: "3-6涓湀"
        },
        {
          name: "娓犻亾浼樺寲绛栫暐",
          description: "鎵╁ぇ绾夸笂鍜屽尰闄㈡笭閬擄紝鍑忓皯浼犵粺闆跺敭娓犻亾",
          revenueChange: 12.0,
          marginChange: 2.8,
          implementationCost: 1200000,
          roi: 280,
          paybackPeriod: 5.8,
          riskLevel: "涓珮",
          timeToImplement: "6-9涓湀"
        },
        {
          name: "杩愯惀鏁堢巼鎻愬崌",
          description: "鏅鸿兘搴撳瓨绯荤粺鍗囩骇鍜屼汉鍛橀厤缃紭鍖?,
          revenueChange: 5.0,
          marginChange: 4.5,
          implementationCost: 680000,
          roi: 450,
          paybackPeriod: 3.2,
          riskLevel: "浣?,
          timeToImplement: "2-4涓湀"
        }
      ];
      
      // 鐢熸垚缁煎悎绛栫暐
      const combinedStrategy = {
        name: "AI鎺ㄨ崘缁煎悎绛栫暐",
        description: "缁煎悎浜у搧缁撴瀯銆佹笭閬撲紭鍖栧拰杩愯惀鏁堢巼鐨勬渶浣崇粍鍚?,
        revenueChange: 15.2,
        marginChange: 5.8,
        implementationCost: 1800000,
        roi: 520,
        paybackPeriod: 3.5,
        riskLevel: "涓?,
        timeToImplement: "6-12涓湀"
      };
      
      // 妯℃嫙鏈潵12涓湀鐨勬暟鎹?
      const monthlyProjection = Array.from({length: 12}, (_, i) => {
        const baseRevenue = baselineRevenue / 12;
        const baseProfit = baselineProfit / 12;
        
        // 鍩哄噯鎯呭喌
        const baseline = {
          revenue: baseRevenue,
          profit: baseProfit,
          margin: parseFloat(baselineMargin)
        };
        
        // 浼樺寲鍚庢儏鍐碉紙澧為暱鏇茬嚎鏄潪绾挎€х殑锛?
        const growthFactor = Math.min(1, (i + 1) / 6); // 鍓?涓湀閫愭瀹炵幇鍏ㄩ儴鏁堟灉
        const optimized = {
          revenue: baseRevenue * (1 + combinedStrategy.revenueChange/100 * growthFactor),
          profit: baseRevenue * (1 + combinedStrategy.revenueChange/100 * growthFactor) * 
                  (parseFloat(baselineMargin) + combinedStrategy.marginChange * growthFactor) / 100,
          margin: parseFloat(baselineMargin) + combinedStrategy.marginChange * growthFactor
        };
        
        return {
          month: `绗?{i+1}鏈坄,
          baseline,
          optimized,
          difference: {
            revenue: optimized.revenue - baseline.revenue,
            profit: optimized.profit - baseline.profit,
            margin: optimized.margin - baseline.margin
          }
        };
      });
      
      // 璁剧疆妯℃嫙缁撴灉
      setProfitSimulationResults({
        baseline: {
          revenue: baselineRevenue,
          profit: baselineProfit,
          margin: baselineMargin
        },
        scenarios,
        combinedStrategy,
        monthlyProjection,
        annualImpact: {
          additionalRevenue: baselineRevenue * combinedStrategy.revenueChange / 100,
          additionalProfit: (baselineRevenue * (1 + combinedStrategy.revenueChange/100) * 
                           (parseFloat(baselineMargin) + combinedStrategy.marginChange) / 100) - baselineProfit,
          newMargin: (parseFloat(baselineMargin) + combinedStrategy.marginChange).toFixed(1)
        }
      });
    }, 2000);
  };

  // 浼樺寲寤鸿璇︽儏
  const handleViewOptimizationDetail = (suggestion) => {
    setSelectedOptimization(suggestion);
    setOptimizationDialogOpen(true);
  };

  // 搴旂敤AI浼樺寲寤鸿锛堟ā鎷燂級
  const handleApplyOptimization = () => {
    setOptimizationDialogOpen(false);
    setAiProfitSimulationOpen(false);
    
    // 鏄剧ず鎴愬姛娑堟伅
    showSnackbar('AI浼樺寲寤鸿宸叉垚鍔熷簲鐢ㄥ埌绯荤粺涓?);
  };

  if (loading) {
    return (
      <Box
        display="flex"
        justifyContent="center"
        alignItems="center"
        minHeight="80vh"
      >
        <CircularProgress />
      </Box>
    );
  }

  if (error) {
    return (
      <Box p={3}>
        <Alert severity="error">{error}</Alert>
      </Box>
    );
  }

  return (
    <Box p={3}>
      <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', mb: 3 }}>
        <Typography variant="h4">涓嵂鑽埧绠＄悊绯荤粺</Typography>
        <Stack direction="row" spacing={2} alignItems="center">
          {/* 鍖哄潡閾惧畨鍏ㄦ爣璇?*/}
          <Button variant="outlined" color="success" onClick={() => setBlockchainOpen(true)}>
            鍖哄潡閾惧畨鍏?
          </Button>
          {/* 閫氱煡鎸夐挳 */}
          <IconButton color="primary" onClick={() => setNotificationOpen(true)}>
            <NotificationsIcon />
          </IconButton>
          <FormControl sx={{ minWidth: 120 }}>
            <Select
              value={timeRange}
              onChange={handleTimeRangeChange}
              size="small"
            >
              <MenuItem value="1涓湀">鏈€杩?涓湀</MenuItem>
              <MenuItem value="3涓湀">鏈€杩?涓湀</MenuItem>
              <MenuItem value="6涓湀">鏈€杩?涓湀</MenuItem>
              <MenuItem value="1骞?>鏈€杩?骞?/MenuItem>
            </Select>
          </FormControl>
          <Button
            variant="outlined"
            startIcon={<Download />}
            onClick={handleExportData}
          >
            瀵煎嚭鏁版嵁
          </Button>
          <Button
            variant="outlined"
            startIcon={<FilterList />}
            onClick={handleFilterDialogOpen}
          >
            绛涢€?
          </Button>
          <Button
            variant="outlined"
            startIcon={<Settings />}
            onClick={handleSettingsDialogOpen}
          >
            鍥捐〃璁剧疆
          </Button>
        </Stack>
      </Box>

      {/* 閫氱煡寮圭獥 */}
      <Dialog open={notificationOpen} onClose={() => setNotificationOpen(false)} maxWidth="xs" fullWidth>
        <DialogTitle>娑堟伅閫氱煡</DialogTitle>
        <DialogContent>
          <List>
            {notifications.map(n => (
              <ListItem key={n.id}>
                <ListItemIcon>
                  {n.type === 'warning' && <Warning color="warning" />}
                  {n.type === 'info' && <Info color="info" />}
                  {n.type === 'error' && <Error color="error" />}
                </ListItemIcon>
                <ListItemText primary={n.message} secondary={n.time} />
              </ListItem>
            ))}
          </List>
        </DialogContent>
        <DialogActions>
          <Button onClick={() => setNotificationOpen(false)}>鍏抽棴</Button>
        </DialogActions>
      </Dialog>

      {/* 鍖哄潡閾惧畨鍏ㄥ脊绐?*/}
      <Dialog open={blockchainOpen} onClose={() => setBlockchainOpen(false)} maxWidth="sm" fullWidth>
        <DialogTitle>鍖哄潡閾炬暟鎹畨鍏ㄨ鏄?/DialogTitle>
        <DialogContent>
          <Typography variant="body1" color="success.main" mb={2}>{blockchainDesc}</Typography>
        </DialogContent>
        <DialogActions>
          <Button onClick={() => setBlockchainOpen(false)}>鍏抽棴</Button>
        </DialogActions>
      </Dialog>

      <Tabs value={activeTab} onChange={handleTabChange} sx={{ mb: 3 }}>
        <Tab icon={<Timeline />} label="閿€鍞垎鏋? />
        <Tab icon={<Inventory />} label="搴撳瓨绠＄悊" />
        <Tab icon={<People />} label="瀹㈡埛绠＄悊" />
        <Tab icon={<Assignment />} label="璁㈠崟澶勭悊" />
        <Tab icon={<Business />} label="缁勭粐缁撴瀯" />
        <Tab icon={<LocalShipping />} label="鍒嗛攢缃戠粶" />
        <Tab icon={<Security />} label="鐩戠鍚堣" />
        <Tab icon={<LocalPharmacy />} label="涓嵂鏉愬垎鏋? />
        <Tab icon={<AttachMoney />} label="鐩堝埄鑳藉姏鍒嗘瀽" />
        <Tab icon={<AIIcon />} label="AI浼樺寲寤鸿" />
      </Tabs>

      {activeTab === 0 && (
        <Grid container spacing={3}>
          {/* 閿€鍞秼鍔?- 鏀硅繘鐗?*/}
          <Grid item xs={12}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Box display="flex" justifyContent="space-between" alignItems="center" mb={2}>
                <Typography variant="h6">閿€鍞秼鍔垮垎鏋?/Typography>
                <FormControl sx={{ minWidth: 120 }}>
                  <Select
                    value={timeRange}
                    onChange={handleTimeRangeChange}
                    size="small"
                  >
                    <MenuItem value="1涓湀">鏈€杩?涓湀</MenuItem>
                    <MenuItem value="3涓湀">鏈€杩?涓湀</MenuItem>
                    <MenuItem value="6涓湀">鏈€杩?涓湀</MenuItem>
                    <MenuItem value="1骞?>鏈€杩?骞?/MenuItem>
                  </Select>
                </FormControl>
              </Box>
              <Box height={300}>
                <ResponsiveContainer width="100%" height="100%">
                  <ComposedChart data={salesData}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="name" />
                    <YAxis yAxisId="left" orientation="left" />
                    <YAxis yAxisId="right" orientation="right" />
                    <RechartsTooltip formatter={(value) => `楼${value.toLocaleString()}`} />
                    <Legend />
                    <Bar yAxisId="left" dataKey="閿€鍞" name="閿€鍞" fill="#8884d8" barSize={20} />
                    <Bar yAxisId="left" dataKey="鎴愭湰" name="鎴愭湰" fill="#ff8042" barSize={20} />
                    <Line yAxisId="right" type="monotone" dataKey="鍒╂鼎" name="鍒╂鼎" stroke="#82ca9d" strokeWidth={3} dot={{ r: 4 }} />
                    <Line yAxisId="right" type="monotone" dataKey="鐩爣" name="閿€鍞洰鏍? stroke="#ff0000" strokeWidth={2} strokeDasharray="5 5" />
                  </ComposedChart>
                </ResponsiveContainer>
              </Box>
              
              {/* 鏂板閿€鍞秼鍔緼I鍒嗘瀽 */}
              <Alert severity="info" sx={{ mt: 2 }}>
                <AlertTitle>AI閿€鍞秼鍔垮垎鏋?/AlertTitle>
                <Typography variant="body2">
                  鏁版嵁鏄剧ず閿€鍞鍛堝搴︽€т笂鍗囪秼鍔匡紝绗洓瀛ｅ害琛ㄧ幇鏈€浣炽€傚埄娑︾巼鍦ㄨ繎鏈熸湁鎵€鎻愬崌锛屼富瑕佸緱鐩婁簬楂樻瘺鍒╀骇鍝侀攢閲忓鍔犮€?
                  寤鸿缁х画鎵╁ぇ楂樻瘺鍒╀骇鍝佺嚎锛屽苟閽堝閿€鍞綆璋锋湡(2-3鏈?鍒跺畾淇冮攢绛栫暐銆?
                </Typography>
              </Alert>
            </Paper>
          </Grid>

          {/* 閿€鍞粺璁″崱鐗?*/}
          <Grid item xs={12} md={3}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography color="textSecondary" gutterBottom>鏈湀閿€鍞</Typography>
              <Typography variant="h4" fontWeight={700} color="#1976d2">
                楼{salesData[salesData.length - 1]?.閿€鍞.toLocaleString()}
              </Typography>
              <Box display="flex" justifyContent="space-between" alignItems="center">
                <Typography variant="body2" color="success.main">
                  <TrendingUp fontSize="small" sx={{verticalAlign: 'middle', mr: 0.5}} />
                  杈冧笂鏈堝闀?{((salesData[salesData.length - 1]?.閿€鍞 / salesData[salesData.length - 2]?.閿€鍞 - 1) * 100).toFixed(1)}%
                </Typography>
                <Typography variant="body2" color={salesData[salesData.length - 1]?.閿€鍞 >= salesData[salesData.length - 1]?.鐩爣 ? "success.main" : "warning.main"}>
                  鐩爣杈炬垚鐜? {(salesData[salesData.length - 1]?.閿€鍞 / salesData[salesData.length - 1]?.鐩爣 * 100).toFixed(1)}%
                </Typography>
              </Box>
            </Paper>
          </Grid>

          <Grid item xs={12} md={3}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography color="textSecondary" gutterBottom>鏈湀鍒╂鼎</Typography>
              <Typography variant="h4" fontWeight={700} color="#1976d2">
                楼{salesData[salesData.length - 1]?.鍒╂鼎.toLocaleString()}
              </Typography>
              <Box display="flex" justifyContent="space-between" alignItems="center">
                <Typography variant="body2" color="success.main">
                  <TrendingUp fontSize="small" sx={{verticalAlign: 'middle', mr: 0.5}} />
                  杈冧笂鏈堝闀?{((salesData[salesData.length - 1]?.鍒╂鼎 / salesData[salesData.length - 2]?.鍒╂鼎 - 1) * 100).toFixed(1)}%
                </Typography>
                <Typography variant="body2">
                  鍒╂鼎鐜? {(salesData[salesData.length - 1]?.鍒╂鼎 / salesData[salesData.length - 1]?.閿€鍞 * 100).toFixed(1)}%
                </Typography>
              </Box>
            </Paper>
          </Grid>

          <Grid item xs={12} md={3}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography color="textSecondary" gutterBottom>鏈湀鎴愭湰</Typography>
              <Typography variant="h4" fontWeight={700} color="#1976d2">
                楼{salesData[salesData.length - 1]?.鎴愭湰.toLocaleString()}
              </Typography>
              <Box display="flex" justifyContent="space-between" alignItems="center">
                <Typography variant="body2" color={
                  (salesData[salesData.length - 1]?.鎴愭湰 / salesData[salesData.length - 2]?.鎴愭湰 - 1) < 0.1 
                  ? "success.main" : "error.main"
                }>
                  <TrendingUp fontSize="small" sx={{verticalAlign: 'middle', mr: 0.5}} />
                  杈冧笂鏈堝闀?{((salesData[salesData.length - 1]?.鎴愭湰 / salesData[salesData.length - 2]?.鎴愭湰 - 1) * 100).toFixed(1)}%
                </Typography>
                <Typography variant="body2">
                  鎴愭湰鐜? {(salesData[salesData.length - 1]?.鎴愭湰 / salesData[salesData.length - 1]?.閿€鍞 * 100).toFixed(1)}%
                </Typography>
              </Box>
            </Paper>
          </Grid>
          
          <Grid item xs={12} md={3}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography color="textSecondary" gutterBottom>閿€鍞搴﹀姣?/Typography>
              <Box height={150}>
                <ResponsiveContainer width="100%" height="100%">
                  <BarChart 
                    data={[
                      { quarter: 'Q1', 閿€鍞: salesData.slice(0, 3).reduce((sum, item) => sum + item.閿€鍞, 0) / 3 },
                      { quarter: 'Q2', 閿€鍞: salesData.slice(3, 6).reduce((sum, item) => sum + item.閿€鍞, 0) / 3 },
                      { quarter: 'Q3', 閿€鍞: salesData.slice(6, 9).reduce((sum, item) => sum + item.閿€鍞, 0) / 3 },
                      { quarter: 'Q4', 閿€鍞: salesData.slice(9, 12).reduce((sum, item) => sum + item.閿€鍞, 0) / 3 }
                    ]}
                  >
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="quarter" />
                    <YAxis />
                    <RechartsTooltip formatter={(value) => `楼${value.toLocaleString()}`} />
                    <Bar dataKey="閿€鍞" fill="#8884d8" />
                  </BarChart>
                </ResponsiveContainer>
              </Box>
            </Paper>
          </Grid>
          
          {/* 閿€鍞幆姣斿悓姣斿垎鏋?*/}
          <Grid item xs={12}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>閿€鍞幆姣斿悓姣斿垎鏋?/Typography>
              <Grid container spacing={3}>
                <Grid item xs={12} md={8}>
                  <Box height={300}>
                    <ResponsiveContainer width="100%" height="100%">
                      <LineChart data={[
                        // 浠婂勾鏁版嵁
                        ...salesData.map(item => ({
                          鏈堜唤: item.name,
                          浠婂勾閿€鍞: item.閿€鍞,
                          鍘诲勾閿€鍞: Math.round(item.閿€鍞 * 0.85), // 妯℃嫙鍘诲勾鏁版嵁
                          鍓嶅勾閿€鍞: Math.round(item.閿€鍞 * 0.7),  // 妯℃嫙鍓嶅勾鏁版嵁
                        }))
                      ]}>
                        <CartesianGrid strokeDasharray="3 3" />
                        <XAxis dataKey="鏈堜唤" />
                        <YAxis />
                        <RechartsTooltip formatter={(value) => `楼${value.toLocaleString()}`} />
                        <Legend />
                        <Line type="monotone" dataKey="浠婂勾閿€鍞" stroke="#8884d8" strokeWidth={3} activeDot={{ r: 8 }} />
                        <Line type="monotone" dataKey="鍘诲勾閿€鍞" stroke="#82ca9d" strokeDasharray="3 3" />
                        <Line type="monotone" dataKey="鍓嶅勾閿€鍞" stroke="#ffc658" strokeDasharray="5 5" />
                      </LineChart>
                    </ResponsiveContainer>
                  </Box>
                </Grid>
                <Grid item xs={12} md={4}>
                  <Box sx={{ height: '100%', display: 'flex', flexDirection: 'column', justifyContent: 'space-between' }}>
                    <Paper sx={{ p: 2, mb: 2, boxShadow: 2, borderRadius: 2, background: '#f8f9fa' }}>
                      <Typography variant="subtitle1" fontWeight="bold" gutterBottom>鐜瘮鍒嗘瀽 (杈冧笂鏈?</Typography>
                      <Typography variant="body1">
                        閿€鍞: <Chip 
                          label={`${((salesData[11].閿€鍞 / salesData[10].閿€鍞 - 1) * 100).toFixed(1)}%`} 
                          color={(salesData[11].閿€鍞 / salesData[10].閿€鍞 - 1) > 0 ? "success" : "error"} 
                          size="small" 
                          sx={{ ml: 1 }}
                        />
                      </Typography>
                      <Typography variant="body1" mt={1}>
                        鍒╂鼎: <Chip 
                          label={`${((salesData[11].鍒╂鼎 / salesData[10].鍒╂鼎 - 1) * 100).toFixed(1)}%`} 
                          color={(salesData[11].鍒╂鼎 / salesData[10].鍒╂鼎 - 1) > 0 ? "success" : "error"} 
                          size="small" 
                          sx={{ ml: 1 }}
                        />
                      </Typography>
                    </Paper>
                    <Paper sx={{ p: 2, boxShadow: 2, borderRadius: 2, background: '#f8f9fa' }}>
                      <Typography variant="subtitle1" fontWeight="bold" gutterBottom>鍚屾瘮鍒嗘瀽 (杈冨幓骞村悓鏈?</Typography>
                      <Typography variant="body1">
                        閿€鍞: <Chip 
                          label="+17.6%" 
                          color="success" 
                          size="small" 
                          sx={{ ml: 1 }}
                        />
                      </Typography>
                      <Typography variant="body1" mt={1}>
                        鍒╂鼎: <Chip 
                          label="+21.3%" 
                          color="success" 
                          size="small" 
                          sx={{ ml: 1 }}
                        />
                      </Typography>
                      <Typography variant="body1" mt={1}>
                        瀹㈠崟浠? <Chip 
                          label="+8.5%" 
                          color="success" 
                          size="small" 
                          sx={{ ml: 1 }}
                        />
                      </Typography>
                    </Paper>
                  </Box>
                </Grid>
              </Grid>
            </Paper>
          </Grid>
        </Grid>
      )}

      {activeTab === 1 && (
        <>
          <Box mb={2} display="flex" justifyContent="flex-end" gap={2}>
            <Button variant="contained" color="primary" onClick={() => setAddMedicineOpen(true)}>
              鏂板涓嵂鑽潗
            </Button>
            <Button variant="outlined" color="secondary" onClick={handleAIPredict}>
              AI棰勬祴
            </Button>
            <Button variant="outlined" color="info" onClick={handleAIAssign}>
              AI鏅鸿兘鍒嗛厤
            </Button>
          </Box>
          {/* AI棰勬祴寮圭獥 */}
          <Dialog open={aiPredictOpen} onClose={() => setAiPredictOpen(false)} maxWidth="md" fullWidth>
            <DialogTitle>AI棰勬祴閿€閲忎笌寤鸿搴撳瓨</DialogTitle>
            <DialogContent>
              <Typography variant="subtitle1" color="info.main" mb={2}>鍩轰簬杩?涓湀閿€閲忥紝AI棰勬祴涓嬫湀閿€閲忓強寤鸿搴撳瓨锛堝缓璁簱瀛?棰勬祴閿€閲徝?.2锛?/Typography>
              <Box sx={{ overflowX: 'auto' }}>
                <table style={{ width: '100%', borderCollapse: 'collapse', marginBottom: 16 }}>
                  <thead>
                    <tr style={{ background: '#f5f7fa' }}>
                      <th style={{ padding: 8 }}>鑽潗</th>
                      <th style={{ padding: 8 }}>杩?鏈堥攢閲?/th>
                      <th style={{ padding: 8 }}>棰勬祴閿€閲?/th>
                      <th style={{ padding: 8 }}>寤鸿搴撳瓨</th>
                      <th style={{ padding: 8 }}>褰撳墠搴撳瓨</th>
                      <th style={{ padding: 8 }}>鐘舵€?/th>
                    </tr>
                  </thead>
                  <tbody>
                    {aiResults.map(r => (
                      <tr key={r.name} style={{ background: r.suggestStock > r.current ? '#fffbe6' : r.suggestStock < r.current * 0.7 ? '#e6f7ff' : 'white' }}>
                        <td style={{ padding: 8 }}>{r.name}</td>
                        <td style={{ padding: 8 }}>{r.last6.join(', ')}</td>
                        <td style={{ padding: 8, color: '#1976d2', fontWeight: 700 }}>{r.predict}</td>
                        <td style={{ padding: 8, color: '#388e3c', fontWeight: 700 }}>{r.suggestStock}</td>
                        <td style={{ padding: 8 }}>{r.current}</td>
                        <td style={{ padding: 8 }}>
                          {r.suggestStock > r.current ? <Chip label="闇€琛ヨ揣" color="warning" size="small" /> : r.suggestStock < r.current * 0.7 ? <Chip label="搴撳瓨杩囧墿" color="info" size="small" /> : <Chip label="鍚堢悊" color="success" size="small" />}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </Box>
              <Box mb={2}>
                <ResponsiveContainer width="100%" height={300}>
                  <BarChart data={aiResults.slice(0, 10)}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="name" />
                    <YAxis />
                    <RechartsTooltip />
                    <Legend />
                    <Bar dataKey="predict" name="棰勬祴閿€閲? fill="#1976d2" />
                    <Bar dataKey="suggestStock" name="寤鸿搴撳瓨" fill="#388e3c" />
                    <Bar dataKey="current" name="褰撳墠搴撳瓨" fill="#ffa726" />
                  </BarChart>
                </ResponsiveContainer>
              </Box>
            </DialogContent>
            <DialogActions>
              <Button onClick={() => setAiPredictOpen(false)}>鍏抽棴</Button>
              <Button onClick={handleApplySuggestStock} variant="contained" color="primary">涓€閿簲鐢ㄥ缓璁簱瀛?/Button>
            </DialogActions>
          </Dialog>
          <Dialog open={addMedicineOpen} onClose={() => setAddMedicineOpen(false)}>
            <DialogTitle>鏂板涓嵂鑽潗</DialogTitle>
            <DialogContent>
              <TextField label="鑽潗鍚嶇О" fullWidth margin="normal" value={newMedicine.name} onChange={e => setNewMedicine({ ...newMedicine, name: e.target.value })} />
              <TextField label="搴撳瓨" type="number" fullWidth margin="normal" value={newMedicine.stock} onChange={e => setNewMedicine({ ...newMedicine, stock: e.target.value })} />
              <TextField label="閿€閲? type="number" fullWidth margin="normal" value={newMedicine.sales} onChange={e => setNewMedicine({ ...newMedicine, sales: e.target.value })} />
              <TextField label="浠锋牸" type="number" fullWidth margin="normal" value={newMedicine.price} onChange={e => setNewMedicine({ ...newMedicine, price: e.target.value })} />
            </DialogContent>
            <DialogActions>
              <Button onClick={() => setAddMedicineOpen(false)}>鍙栨秷</Button>
              <Button onClick={handleAddMedicine} variant="contained">娣诲姞</Button>
            </DialogActions>
          </Dialog>
          {/* 鑽潗璇︽儏寮圭獥 */}
          <Dialog open={medicineDetailOpen} onClose={() => setMedicineDetailOpen(false)}>
            <DialogTitle>鑽潗璇︽儏</DialogTitle>
            <DialogContent>
              {selectedMedicine && (
                <>
                  <TextField label="鑽潗鍚嶇О" fullWidth margin="normal" value={selectedMedicine.name} onChange={e => setSelectedMedicine({ ...selectedMedicine, name: e.target.value, original: selectedMedicine.original })} />
                  <TextField label="搴撳瓨" type="number" fullWidth margin="normal" value={selectedMedicine.stock} onChange={e => setSelectedMedicine({ ...selectedMedicine, stock: e.target.value, original: selectedMedicine.original })} />
                  <TextField label="閿€閲? type="number" fullWidth margin="normal" value={selectedMedicine.sales} onChange={e => setSelectedMedicine({ ...selectedMedicine, sales: e.target.value, original: selectedMedicine.original })} />
                  <TextField label="浠锋牸" type="number" fullWidth margin="normal" value={selectedMedicine.price} onChange={e => setSelectedMedicine({ ...selectedMedicine, price: e.target.value, original: selectedMedicine.original })} />
                </>
              )}
            </DialogContent>
            <DialogActions>
              <Button onClick={handleDeleteMedicine} color="error">鍒犻櫎</Button>
              <Button onClick={handleEditMedicine} variant="contained">淇濆瓨</Button>
            </DialogActions>
          </Dialog>
          <Grid container spacing={3}>
            {/* 搴撳瓨鍒嗗竷 */}
            <Grid item xs={12} md={6}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>
                  搴撳瓨鍒嗗竷
                </Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <PieChart>
                      <Pie
                        data={inventoryData?.categories}
                        cx="50%"
                        cy="50%"
                        labelLine={false}
                        label={({ name, percent }) => `${name} ${(percent * 100).toFixed(0)}%`}
                        outerRadius={80}
                        fill="#8884d8"
                        dataKey="value"
                      >
                        {inventoryData?.categories.map((entry, index) => (
                          <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                        ))}
                      </Pie>
                      <RechartsTooltip />
                    </PieChart>
                  </ResponsiveContainer>
                </Box>
              </Paper>
            </Grid>

            {/* 搴撳瓨棰勮 */}
            <Grid item xs={12} md={6}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>
                  搴撳瓨棰勮
                </Typography>
                <List>
                  {inventoryData?.stockAlerts.map((alert, index) => (
                    <ListItem key={index}>
                      <ListItemIcon>
                        <Warning color="error" />
                      </ListItemIcon>
                      <ListItemText
                        primary={alert.name}
                        secondary={`褰撳墠搴撳瓨: ${alert.current} | 鏈€浣庡簱瀛? ${alert.min}`}
                      />
                      <Button variant="outlined" size="small">
                        琛ヨ揣
                      </Button>
                    </ListItem>
                  ))}
                </List>
              </Paper>
            </Grid>

            {/* 鐑攢鍟嗗搧 */}
            <Grid item xs={12}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>
                  鐑攢鍟嗗搧
                </Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={inventoryData?.topProducts}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="name" />
                      <YAxis />
                      <RechartsTooltip />
                      <Legend />
                      <Bar dataKey="stock" name="搴撳瓨" fill="#8884d8" onClick={(_, idx) => {
                        const med = inventoryData.topProducts[idx];
                        setSelectedMedicine({ ...med, original: med });
                        setMedicineDetailOpen(true);
                      }} cursor="pointer" />
                      <Bar dataKey="sales" name="閿€閲? fill="#82ca9d" onClick={(_, idx) => {
                        const med = inventoryData.topProducts[idx];
                        setSelectedMedicine({ ...med, original: med });
                        setMedicineDetailOpen(true);
                      }} cursor="pointer" />
                    </BarChart>
                  </ResponsiveContainer>
                </Box>
              </Paper>
            </Grid>

            {/* 搴撳瓨鍙樺寲瓒嬪娍 */}
            <Grid item xs={12} md={6}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>搴撳瓨鍙樺寲瓒嬪娍</Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <LineChart data={inventoryTrend}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="month" />
                      <YAxis />
                      <RechartsTooltip />
                      <Legend />
                      <Line type="monotone" dataKey="搴撳瓨" stroke="#8884d8" />
                    </LineChart>
                  </ResponsiveContainer>
                </Box>
              </Paper>
            </Grid>
          </Grid>
        </>
      )}

      {activeTab === 2 && customersData && (
        <>
          <Box mb={2} display="flex" justifyContent="flex-end">
            <Button variant="contained" color="primary" onClick={() => setAddCustomerOpen(true)}>
              鏂板瀹㈡埛
            </Button>
          </Box>
          {/* 瀹㈡埛璇︽儏寮圭獥 */}
          <Dialog open={customerDetailOpen} onClose={() => setCustomerDetailOpen(false)}>
            <DialogTitle>瀹㈡埛璇︽儏</DialogTitle>
            <DialogContent>
              {selectedCustomer && (
                <>
                  <TextField label="瀹㈡埛鍚嶇О" fullWidth margin="normal" value={selectedCustomer.name} onChange={e => setSelectedCustomer({ ...selectedCustomer, name: e.target.value, original: selectedCustomer.original })} />
                  <TextField label="璐拱娆℃暟" type="number" fullWidth margin="normal" value={selectedCustomer.purchases} onChange={e => setSelectedCustomer({ ...selectedCustomer, purchases: e.target.value, original: selectedCustomer.original })} />
                  <TextField label="鎬绘秷璐? type="number" fullWidth margin="normal" value={selectedCustomer.total} onChange={e => setSelectedCustomer({ ...selectedCustomer, total: e.target.value, original: selectedCustomer.original })} />
                  <TextField label="鏈€杩戣闂? fullWidth margin="normal" value={selectedCustomer.lastVisit} onChange={e => setSelectedCustomer({ ...selectedCustomer, lastVisit: e.target.value, original: selectedCustomer.original })} />
                </>
              )}
            </DialogContent>
            <DialogActions>
              <Button onClick={handleDeleteCustomer} color="error">鍒犻櫎</Button>
              <Button onClick={handleEditCustomer} variant="contained">淇濆瓨</Button>
            </DialogActions>
          </Dialog>
          <Grid container spacing={3}>
            {/* 瀹㈡埛澧為暱瓒嬪娍 */}
            <Grid item xs={12}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>
                  瀹㈡埛澧為暱瓒嬪娍
                </Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <LineChart data={customersData?.growth}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="name" />
                      <YAxis />
                      <RechartsTooltip />
                      <Legend />
                      <Line type="monotone" dataKey="鏂板鎴? stroke="#8884d8" />
                      <Line type="monotone" dataKey="鑰佸鎴? stroke="#82ca9d" />
                    </LineChart>
                  </ResponsiveContainer>
                </Box>
              </Paper>
            </Grid>

            {/* 瀹㈡埛缁熻鍗＄墖 */}
            <Grid item xs={12} md={3}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography color="textSecondary" gutterBottom>
                  鎬诲鎴锋暟
                </Typography>
                <Typography variant="h4" fontWeight={700} color="#1976d2">
                  {customersData?.total}
                </Typography>
              </Paper>
            </Grid>

            <Grid item xs={12} md={3}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography color="textSecondary" gutterBottom>
                  鏂板瀹㈡埛
                </Typography>
                <Typography variant="h4" fontWeight={700} color="#1976d2">
                  {customersData?.new}
                </Typography>
              </Paper>
            </Grid>

            <Grid item xs={12} md={3}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography color="textSecondary" gutterBottom>
                  娲昏穬瀹㈡埛
                </Typography>
                <Typography variant="h4" fontWeight={700} color="#1976d2">
                  {customersData?.active}
                </Typography>
              </Paper>
            </Grid>

            <Grid item xs={12} md={3}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography color="textSecondary" gutterBottom>
                  闈炴椿璺冨鎴?
                </Typography>
                <Typography variant="h4" fontWeight={700} color="#1976d2">
                  {customersData?.inactive}
                </Typography>
              </Paper>
            </Grid>

            {/* 閲嶈瀹㈡埛 */}
            <Grid item xs={12}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>
                  閲嶈瀹㈡埛
                </Typography>
                <List>
                  {customersData?.topCustomers.map((customer, index) => (
                    <ListItem key={index} button onClick={() => {
                      setSelectedCustomer({ ...customer, original: customer });
                      setCustomerDetailOpen(true);
                    }}>
                      <ListItemIcon>
                        <Star color="primary" />
                      </ListItemIcon>
                      <ListItemText
                        primary={customer.name}
                        secondary={`璐拱娆℃暟: ${customer.purchases} | 鎬绘秷璐? 楼${customer.total} | 鏈€杩戣闂? ${customer.lastVisit}`}
                      />
                      <Button variant="outlined" size="small">
                        鏌ョ湅璇︽儏
                      </Button>
                    </ListItem>
                  ))}
                </List>
              </Paper>
            </Grid>

            {/* 瀹㈡埛娲昏穬搴﹀垎甯?*/}
            <Grid item xs={12} md={6}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>瀹㈡埛娲昏穬搴﹀垎甯?/Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <PieChart>
                      <Pie data={customerActivePie} dataKey="value" nameKey="name" cx="50%" cy="50%" outerRadius={80} label>
                        {customerActivePie.map((entry, idx) => (
                          <Cell key={`cell-${idx}`} fill={COLORS[idx % COLORS.length]} />
                        ))}
                      </Pie>
                      <RechartsTooltip />
                      <Legend />
                    </PieChart>
                  </ResponsiveContainer>
                </Box>
              </Paper>
            </Grid>

            {/* 瀹㈡埛澧為暱瓒嬪娍AI棰勬祴 */}
            {customerGrowthAI.length > 0 && (
              <Grid item xs={12} md={6}>
                <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #e3ffe8 0%, #c3cfe2 100%)' }}>
                  <Typography variant="h6" gutterBottom>AI棰勬祴鏈潵3涓湀瀹㈡埛澧為暱瓒嬪娍</Typography>
                  <Box height={300}>
                    <ResponsiveContainer width="100%" height="100%">
                      <LineChart data={customerGrowthAI}>
                        <CartesianGrid strokeDasharray="3 3" />
                        <XAxis dataKey="name" />
                        <YAxis />
                        <RechartsTooltip />
                        <Legend />
                        <Line type="monotone" dataKey="棰勬祴瀹㈡埛" stroke="#1976d2" />
                      </LineChart>
                    </ResponsiveContainer>
                  </Box>
                </Paper>
              </Grid>
            )}
          </Grid>
        </>
      )}

      {activeTab === 3 && ordersData && (
        <>
          <Box mb={2} display="flex" justifyContent="flex-end" gap={2}>
            <Button variant="outlined" color="info" onClick={handleAIOrderPredict}>
              AI璁㈠崟棰勬祴
            </Button>
          </Box>
          {/* AI璁㈠崟棰勬祴寮圭獥 */}
          <Dialog open={aiOrderPredictOpen} onClose={() => setAiOrderPredictOpen(false)} maxWidth="sm" fullWidth>
            <DialogTitle>AI璁㈠崟澶勭悊棰勬祴</DialogTitle>
            <DialogContent>
              <Typography variant="subtitle1" color="info.main" mb={2}>AI棰勬祴鏈潵3涓湀璁㈠崟閲忥紝骞跺彲鑷姩閫氳繃鎵€鏈夊緟澶勭悊璁㈠崟</Typography>
              <Box height={300}>
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={aiOrderForecast}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="name" />
                    <YAxis />
                    <RechartsTooltip />
                    <Legend />
                    <Line type="monotone" dataKey="棰勬祴璁㈠崟" stroke="#1976d2" />
                  </LineChart>
                </ResponsiveContainer>
              </Box>
            </DialogContent>
            <DialogActions>
              <Button onClick={() => setAiOrderPredictOpen(false)}>鍏抽棴</Button>
              <Button onClick={handleAutoCompleteOrders} variant="contained" color="primary">鑷姩閫氳繃鎵€鏈夊緟澶勭悊璁㈠崟</Button>
            </DialogActions>
          </Dialog>
          {/* 璁㈠崟璇︽儏寮圭獥 */}
          <Dialog open={orderDetailOpen} onClose={() => setOrderDetailOpen(false)}>
            <DialogTitle>璁㈠崟璇︽儏</DialogTitle>
            <DialogContent>
              {selectedOrder && (
                <>
                  <TextField label="璁㈠崟鍙? fullWidth margin="normal" value={selectedOrder.id} disabled />
                  <TextField label="瀹㈡埛" fullWidth margin="normal" value={selectedOrder.customer} onChange={e => setSelectedOrder({ ...selectedOrder, customer: e.target.value, original: selectedOrder.original })} />
                  <TextField label="閲戦" type="number" fullWidth margin="normal" value={selectedOrder.amount} onChange={e => setSelectedOrder({ ...selectedOrder, amount: e.target.value, original: selectedOrder.original })} />
                  <FormControl fullWidth margin="normal">
                    <Select value={selectedOrder.status} onChange={e => setSelectedOrder({ ...selectedOrder, status: e.target.value, original: selectedOrder.original })}>
                      <MenuItem value="pending">寰呭鐞?/MenuItem>
                      <MenuItem value="completed">宸插畬鎴?/MenuItem>
                      <MenuItem value="cancelled">宸插彇娑?/MenuItem>
                      <MenuItem value="processing">澶勭悊涓?/MenuItem>
                    </Select>
                  </FormControl>
                  <TextField label="鏃ユ湡" fullWidth margin="normal" value={selectedOrder.date} onChange={e => setSelectedOrder({ ...selectedOrder, date: e.target.value, original: selectedOrder.original })} />
                </>
              )}
            </DialogContent>
            <DialogActions>
              <Button onClick={handleEditOrder} variant="contained">淇濆瓨</Button>
            </DialogActions>
          </Dialog>
          <Grid container spacing={3}>
            {/* 璁㈠崟缁熻鍗＄墖 */}
            <Grid item xs={12} md={3}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography color="textSecondary" gutterBottom>
                  鎬昏鍗曟暟
                </Typography>
                <Typography variant="h4" fontWeight={700} color="#1976d2">
                  {ordersData?.total}
                </Typography>
              </Paper>
            </Grid>

            <Grid item xs={12} md={3}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography color="textSecondary" gutterBottom>
                  寰呭鐞嗚鍗?
                </Typography>
                <Typography variant="h4" fontWeight={700} color="#1976d2">
                  {ordersData?.pending}
                </Typography>
              </Paper>
            </Grid>

            <Grid item xs={12} md={3}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography color="textSecondary" gutterBottom>
                  宸插畬鎴愯鍗?
                </Typography>
                <Typography variant="h4" fontWeight={700} color="#1976d2">
                  {ordersData?.completed}
                </Typography>
              </Paper>
            </Grid>

            <Grid item xs={12} md={3}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography color="textSecondary" gutterBottom>
                  宸插彇娑堣鍗?
                </Typography>
                <Typography variant="h4" fontWeight={700} color="#1976d2">
                  {ordersData?.cancelled}
                </Typography>
              </Paper>
            </Grid>

            {/* 鏈€杩戣鍗?*/}
            <Grid item xs={12}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>
                  鏈€杩戣鍗?
                </Typography>
                <List>
                  {ordersData?.recentOrders.map((order, index) => (
                    <ListItem key={index} button onClick={() => {
                      setSelectedOrder({ ...order, original: order });
                      setOrderDetailOpen(true);
                    }}>
                      <ListItemIcon>
                        {order.status === 'completed' ? (
                          <CheckCircle color="success" />
                        ) : order.status === 'pending' ? (
                          <Warning color="warning" />
                        ) : (
                          <Error color="error" />
                        )}
                      </ListItemIcon>
                      <ListItemText
                        primary={`璁㈠崟鍙? ${order.id}`}
                        secondary={`瀹㈡埛: ${order.customer} | 閲戦: 楼${order.amount} | 鐘舵€? ${order.status} | 鏃ユ湡: ${order.date}`}
                      />
                      <Button variant="outlined" size="small">
                        澶勭悊
                      </Button>
                    </ListItem>
                  ))}
                </List>
              </Paper>
            </Grid>

            {/* 璁㈠崟鐘舵€佸垎甯?*/}
            <Grid item xs={12} md={6}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>璁㈠崟鐘舵€佸垎甯?/Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <PieChart>
                      <Pie data={orderStatusPie} dataKey="value" nameKey="name" cx="50%" cy="50%" outerRadius={80} label>
                        {orderStatusPie.map((entry, idx) => (
                          <Cell key={`cell-${idx}`} fill={COLORS[idx % COLORS.length]} />
                        ))}
                      </Pie>
                      <RechartsTooltip />
                      <Legend />
                    </PieChart>
                  </ResponsiveContainer>
                </Box>
              </Paper>
            </Grid>
          </Grid>
        </>
      )}

      {activeTab === 5 && distributionData && (
        <>
          <Grid container spacing={3}>
            {/* 閿€鍞笭閬撳垎鏋?*/}
            <Grid item xs={12} md={6}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>
                  閿€鍞笭閬撳垎鏋?
                </Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={distributionData?.channels}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="name" />
                      <YAxis />
                      <RechartsTooltip />
                      <Legend />
                      <Bar dataKey="sales" name="閿€鍞" fill="#8884d8" />
                      <Bar dataKey="customers" name="瀹㈡埛鏁? fill="#82ca9d" />
                    </BarChart>
                  </ResponsiveContainer>
                </Box>
              </Paper>
            </Grid>

            {/* 鍖哄煙閿€鍞垎鏋?*/}
            <Grid item xs={12} md={6}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>
                  鍖哄煙閿€鍞垎鏋?
                </Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={distributionData?.regions}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="name" />
                      <YAxis />
                      <RechartsTooltip />
                      <Legend />
                      <Bar dataKey="sales" name="閿€鍞" fill="#8884d8" />
                      <Bar dataKey="stores" name="闂ㄥ簵鏁? fill="#82ca9d" />
                    </BarChart>
                  </ResponsiveContainer>
                </Box>
              </Paper>
            </Grid>

            {/* 娓犻亾澧為暱瓒嬪娍 */}
            {channelGrowthTrend.length > 0 && (
              <Grid item xs={12}>
                <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #e3f2fd 0%, #c3cfe2 100%)' }}>
                  <Typography variant="h6" gutterBottom>娓犻亾澧為暱瓒嬪娍锛圓I鍒嗘瀽锛?/Typography>
                  <Box height={300}>
                    <ResponsiveContainer width="100%" height="100%">
                      <LineChart>
                        <CartesianGrid strokeDasharray="3 3" />
                        <XAxis dataKey="month" type="category" allowDuplicatedCategory={false} />
                        <YAxis />
                        <RechartsTooltip />
                        <Legend />
                        {channelGrowthTrend.map((c, idx) => (
                          <Line key={c.name} type="monotone" dataKey={c.name} data={c.data.map((v, i) => ({ month: `${i + 1}鏈坄, [c.name]: v }))} stroke={COLORS[idx % COLORS.length]} dot />
                        ))}
                      </LineChart>
                    </ResponsiveContainer>
                  </Box>
                  <Box mt={2}>
                    <Alert severity="info">{channelGrowthExplain}</Alert>
                  </Box>
                </Paper>
              </Grid>
            )}
          </Grid>
        </>
      )}

      {activeTab === 4 && (
        <Grid container spacing={3}>
          {/* 閮ㄩ棬缁╂晥 */}
          <Grid item xs={12}>
            <Paper sx={{ p: 2 }}>
              <Typography variant="h6" gutterBottom>
                閮ㄩ棬缁╂晥
              </Typography>
              <Box height={400}>
                <ResponsiveContainer width="100%" height="100%">
                  <RadarChart data={organizationData?.performance}>
                    <PolarGrid />
                    <PolarAngleAxis dataKey="name" />
                    <PolarRadiusAxis />
                    <Radar
                      name="缁╂晥鎸囨爣"
                      dataKey="瀹屾垚鐜?
                      stroke="#8884d8"
                      fill="#8884d8"
                      fillOpacity={0.6}
                    />
                    <Radar
                      name="缁╂晥鎸囨爣"
                      dataKey="璐ㄩ噺"
                      stroke="#82ca9d"
                      fill="#82ca9d"
                      fillOpacity={0.6}
                    />
                    <Radar
                      name="缁╂晥鎸囨爣"
                      dataKey="鏁堢巼"
                      stroke="#ffc658"
                      fill="#ffc658"
                      fillOpacity={0.6}
                    />
                    <RechartsTooltip />
                    <Legend />
                  </RadarChart>
                </ResponsiveContainer>
              </Box>
            </Paper>
          </Grid>

          {/* 閮ㄩ棬淇℃伅 */}
          <Grid item xs={12}>
            <Paper sx={{ p: 2 }}>
              <Typography variant="h6" gutterBottom>
                閮ㄩ棬淇℃伅
              </Typography>
              <List>
                {organizationData?.departments.map((dept, index) => (
                  <ListItem key={index}>
                    <ListItemIcon>
                      <Business />
                    </ListItemIcon>
                    <ListItemText
                      primary={dept.name}
                      secondary={`鍛樺伐鏁? ${dept.staff} | 棰勭畻: 楼${dept.budget.toLocaleString()}`}
                    />
                    <Button variant="outlined" size="small">
                      鏌ョ湅璇︽儏
                    </Button>
                  </ListItem>
                ))}
              </List>
            </Paper>
          </Grid>
        </Grid>
      )}

      {activeTab === 6 && (
        <Grid container spacing={3}>
          {/* 璇佷功鐘舵€?*/}
          <Grid item xs={12} md={6}>
            <Paper sx={{ p: 2 }}>
              <Typography variant="h6" gutterBottom>
                璇佷功鐘舵€?
              </Typography>
              <List>
                {complianceData?.certificates.map((cert, index) => (
                  <ListItem key={index}>
                    <ListItemIcon>
                      {cert.status === 'valid' ? (
                        <CheckCircle color="success" />
                      ) : (
                        <Warning color="error" />
                      )}
                    </ListItemIcon>
                    <ListItemText
                      primary={cert.name}
                      secondary={`鐘舵€? ${cert.status} | 鍒版湡鏃? ${cert.expiry}`}
                    />
                    <Button variant="outlined" size="small">
                      鏌ョ湅璇︽儏
                    </Button>
                  </ListItem>
                ))}
              </List>
            </Paper>
          </Grid>

          {/* 妫€鏌ヨ褰?*/}
          <Grid item xs={12} md={6}>
            <Paper sx={{ p: 2 }}>
              <Typography variant="h6" gutterBottom>
                妫€鏌ヨ褰?
              </Typography>
              <List>
                {complianceData?.inspections.map((inspection, index) => (
                  <ListItem key={index}>
                    <ListItemIcon>
                      {inspection.result === '閫氳繃' ? (
                        <CheckCircle color="success" />
                      ) : (
                        <Error color="error" />
                      )}
                    </ListItemIcon>
                    <ListItemText
                      primary={inspection.type}
                      secondary={`鏃ユ湡: ${inspection.date} | 缁撴灉: ${inspection.result}`}
                    />
                    <Button variant="outlined" size="small">
                      鏌ョ湅鎶ュ憡
                    </Button>
                  </ListItem>
                ))}
              </List>
            </Paper>
          </Grid>

          {/* 杩濊璁板綍 */}
          <Grid item xs={12}>
            <Paper sx={{ p: 2 }}>
              <Typography variant="h6" gutterBottom>
                杩濊璁板綍
              </Typography>
              <List>
                {complianceData?.violations.map((violation, index) => (
                  <ListItem key={index}>
                    <ListItemIcon>
                      <Warning color="warning" />
                    </ListItemIcon>
                    <ListItemText
                      primary={violation.type}
                      secondary={`鏃ユ湡: ${violation.date} | 鐘舵€? ${violation.status}`}
                    />
                    <Button variant="outlined" size="small">
                      鏌ョ湅璇︽儏
                    </Button>
                  </ListItem>
                ))}
              </List>
            </Paper>
          </Grid>
        </Grid>
      )}

      {activeTab === 7 && (
        <Grid container spacing={3}>
          {/* 浠锋牸瓒嬪娍瀵规瘮 */}
          <Grid item xs={12}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>涓昏涓嵂鏉愪环鏍艰秼鍔垮姣?/Typography>
              <Box height={300}>
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={mockData.medicineData.priceTrend}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="month" />
                    <YAxis />
                    <RechartsTooltip />
                    <Legend />
                    {Object.keys(mockData.medicineData.priceTrend[0]).filter(k => k !== 'month').map((key, idx) => (
                      <Line key={key} type="monotone" dataKey={key} stroke={COLORS[idx % COLORS.length]} />
                    ))}
                  </LineChart>
                </ResponsiveContainer>
              </Box>
            </Paper>
          </Grid>
          {/* 閿€閲忎笌浠锋牸鐩稿叧鎬?*/}
          <Grid item xs={12} md={6}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>鑽潗閿€閲忎笌浠锋牸鐩稿叧鎬?/Typography>
              <Box height={300}>
                <ResponsiveContainer width="100%" height="100%">
                  <ScatterChart>
                    <CartesianGrid />
                    <XAxis dataKey="浠锋牸" name="浠锋牸" />
                    <YAxis dataKey="閿€閲? name="閿€閲? />
                    <RechartsTooltip cursor={{ strokeDasharray: '3 3' }} />
                    <Scatter name="鑽潗" data={mockData.medicineData.scatterData} fill="#8884d8" />
                  </ScatterChart>
                </ResponsiveContainer>
              </Box>
            </Paper>
          </Grid>
          {/* 鍝佽川闆疯揪鍥?*/}
          <Grid item xs={12} md={6}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>鑽潗鍝佽川闆疯揪鍥?/Typography>
              <Box height={300}>
                <ResponsiveContainer width="100%" height="100%">
                  <RadarChart data={mockData.medicineData.qualityRadar}>
                    <PolarGrid />
                    <PolarAngleAxis dataKey="name" />
                    <PolarRadiusAxis />
                    <Radar name="绾害" dataKey="绾害" stroke="#8884d8" fill="#8884d8" fillOpacity={0.6} />
                    <Radar name="姘村垎" dataKey="姘村垎" stroke="#82ca9d" fill="#82ca9d" fillOpacity={0.6} />
                    <Radar name="鑹叉辰" dataKey="鑹叉辰" stroke="#ffc658" fill="#ffc658" fillOpacity={0.6} />
                    <Legend />
                  </RadarChart>
                </ResponsiveContainer>
              </Box>
            </Paper>
          </Grid>
          {/* 澶勬柟鐑姏鍒嗘瀽 - 鏇存柊涓鸿缁嗙増鏈?*/}
          <Grid item xs={12}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Box display="flex" justifyContent="space-between" alignItems="center" mb={2}>
                <Typography variant="h6">甯哥敤澶勬柟缁勫悎鍒嗘瀽</Typography>
                <Button variant="outlined" color="primary" onClick={() => setPrescriptionAnalysisOpen(true)}>
                  鏌ョ湅鍏ㄩ儴鍒嗘瀽
                </Button>
              </Box>
              <Grid container spacing={2}>
                {mockData.medicineData.prescriptionCombos.map((combo, idx) => (
                  <Grid item xs={12} sm={6} md={3} key={idx}>
                    <Card 
                      sx={{ 
                        boxShadow: 2, 
                        borderRadius: 2,
                        height: '100%',
                        cursor: 'pointer',
                        transition: 'transform 0.3s, box-shadow 0.3s',
                        '&:hover': { transform: 'translateY(-5px)', boxShadow: 5 }
                      }}
                      onClick={() => {
                        setSelectedPrescription(combo.combo.join('+'));
                        setPrescriptionDetailOpen(true);
                      }}
                    >
                      <CardContent>
                        <Typography variant="h6" color="primary" gutterBottom>
                          {combinationAnalysis.find(c => JSON.stringify(c.combo) === JSON.stringify(combo.combo))?.name || combo.combo.join(' + ')}
                        </Typography>
                        <Typography variant="body2" color="text.secondary" gutterBottom>
                          缁勫悎: {combo.combo.join(' + ')}
                        </Typography>
                        <Typography variant="body2">
                          浣跨敤棰戠巼: <Chip size="small" label={combo.count} color="primary" />
                        </Typography>
                        <Typography variant="body2" color="text.secondary" mt={1}>
                          鐐瑰嚮鏌ョ湅璇︽儏...
                        </Typography>
                      </CardContent>
                    </Card>
                  </Grid>
                ))}
              </Grid>
            </Paper>
          </Grid>
          {/* 瀛ｈ妭鎬ч渶姹傚垎鏋?*/}
          <Grid item xs={12} md={6}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>瀛ｈ妭鎬ч渶姹傚垎鏋?/Typography>
              <BarChart width={400} height={300} data={mockData.medicineData.seasonDemand}>
                <CartesianGrid strokeDasharray="3 3" />
                <XAxis dataKey="season" />
                <YAxis />
                <RechartsTooltip />
                <Legend />
                <Bar dataKey="demand" fill="#8884d8" />
              </BarChart>
            </Paper>
          </Grid>
        </Grid>
      )}

      {/* 澶勬柟璇︽儏寮圭獥 */}
      <Dialog open={prescriptionDetailOpen} onClose={() => setPrescriptionDetailOpen(false)} maxWidth="md" fullWidth>
        <DialogTitle>
          {selectedPrescription && prescriptionDetails[selectedPrescription] 
            ? prescriptionDetails[selectedPrescription].name 
            : '澶勬柟璇︽儏'
          }
        </DialogTitle>
        <DialogContent dividers>
          {selectedPrescription && prescriptionDetails[selectedPrescription] && (
            <Box>
              <Typography variant="h6" color="primary" gutterBottom>鍩烘湰淇℃伅</Typography>
              <Grid container spacing={2} mb={3}>
                <Grid item xs={12} md={6}>
                  <Typography variant="subtitle1">缁勬垚锛歿selectedPrescription.replace(/\+/g, '銆?)}</Typography>
                  <Typography variant="subtitle1" mt={1}>鍔熸晥锛歿prescriptionDetails[selectedPrescription].effect}</Typography>
                  <Typography variant="subtitle1" mt={1}>鐢ㄦ硶锛歿prescriptionDetails[selectedPrescription].usage}</Typography>
                </Grid>
                <Grid item xs={12} md={6}>
                  <Typography variant="subtitle1">閫傚簲鐥囷細{prescriptionDetails[selectedPrescription].indication}</Typography>
                  <Typography variant="subtitle1" mt={1}>绂佸繉锛歿prescriptionDetails[selectedPrescription].contraindication}</Typography>
                  <Typography variant="subtitle1" mt={1}>鐢ㄩ噺锛歿prescriptionDetails[selectedPrescription].dosage}</Typography>
                </Grid>
              </Grid>

              <Divider sx={{ my: 2 }} />
              
              <Typography variant="h6" color="primary" gutterBottom>鍗忓悓浣滅敤鍒嗘瀽</Typography>
              <Typography variant="body1" paragraph>
                {prescriptionDetails[selectedPrescription].synergy}
              </Typography>

              <Divider sx={{ my: 2 }} />
              
              <Typography variant="h6" color="primary" gutterBottom>涓村簥搴旂敤</Typography>
              <Typography variant="body1" paragraph>
                {prescriptionDetails[selectedPrescription].clinicalUsage}
              </Typography>

              <Divider sx={{ my: 2 }} />
              
              <Typography variant="h6" color="primary" gutterBottom>鐮旂┒璇佹嵁</Typography>
              <Typography variant="body1" paragraph>
                {prescriptionDetails[selectedPrescription].researchEvidence}
              </Typography>
            </Box>
          )}
        </DialogContent>
        <DialogActions>
          <Button onClick={() => setPrescriptionDetailOpen(false)}>鍏抽棴</Button>
        </DialogActions>
      </Dialog>

      {/* 澶勬柟缁勫悎鍒嗘瀽寮圭獥 */}
      <Dialog open={prescriptionAnalysisOpen} onClose={() => setPrescriptionAnalysisOpen(false)} maxWidth="lg" fullWidth>
        <DialogTitle>甯哥敤澶勬柟缁勫悎璇︾粏鍒嗘瀽</DialogTitle>
        <DialogContent dividers>
          <Box sx={{ overflowX: 'auto' }}>
            <table style={{ width: '100%', borderCollapse: 'collapse', marginBottom: 16 }}>
              <thead>
                <tr style={{ background: '#f5f7fa' }}>
                  <th style={{ padding: 10, borderBottom: '1px solid #e0e0e0' }}>澶勬柟鍚嶇О</th>
                  <th style={{ padding: 10, borderBottom: '1px solid #e0e0e0' }}>缁勬垚</th>
                  <th style={{ padding: 10, borderBottom: '1px solid #e0e0e0' }}>璇︾粏鍒嗘瀽</th>
                  <th style={{ padding: 10, borderBottom: '1px solid #e0e0e0' }}>浣跨敤瓒嬪娍</th>
                  <th style={{ padding: 10, borderBottom: '1px solid #e0e0e0' }}>涓村簥搴旂敤</th>
                  <th style={{ padding: 10, borderBottom: '1px solid #e0e0e0' }}>鎿嶄綔</th>
                </tr>
              </thead>
              <tbody>
                {combinationAnalysis.map((item, index) => (
                  <tr key={index} style={{ borderBottom: '1px solid #e0e0e0' }}>
                    <td style={{ padding: 10, fontWeight: 'bold' }}>{item.name}</td>
                    <td style={{ padding: 10 }}>{item.combo.join('銆?)}</td>
                    <td style={{ padding: 10 }}>{item.analysis}</td>
                    <td style={{ padding: 10 }}>{item.trend}</td>
                    <td style={{ padding: 10 }}>{item.clinical}</td>
                    <td style={{ padding: 10 }}>
                      <Button 
                        size="small" 
                        variant="outlined" 
                        onClick={() => {
                          setSelectedPrescription(item.combo.join('+'));
                          setPrescriptionDetailOpen(true);
                          setPrescriptionAnalysisOpen(false);
                        }}
                      >
                        璇︽儏
                      </Button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </Box>
          
          <Typography variant="h6" color="primary" mt={4}>缁勫悎鐤楁晥姣旇緝</Typography>
          <Box height={300} mt={2}>
            <ResponsiveContainer width="100%" height="100%">
              <BarChart 
                data={combinationAnalysis.map(item => {
                  const combo = mockData.medicineData.prescriptionCombos.find(
                    c => JSON.stringify(c.combo) === JSON.stringify(item.combo)
                  );
                  return {
                    name: item.name,
                    棰戞: combo?.count || 0,
                    // 闅忔満鐢熸垚鐤楁晥鏁版嵁鐢ㄤ簬灞曠ず
                    鐤楁晥: Math.floor(Math.random() * 20) + 80,
                    渚濅粠鎬? Math.floor(Math.random() * 15) + 75
                  };
                })}
              >
                <CartesianGrid strokeDasharray="3 3" />
                <XAxis dataKey="name" />
                <YAxis />
                <RechartsTooltip />
                <Legend />
                <Bar dataKey="棰戞" fill="#8884d8" />
                <Bar dataKey="鐤楁晥" fill="#82ca9d" />
                <Bar dataKey="渚濅粠鎬? fill="#ffc658" />
              </BarChart>
            </ResponsiveContainer>
          </Box>
        </DialogContent>
        <DialogActions>
          <Button onClick={() => setPrescriptionAnalysisOpen(false)}>鍏抽棴</Button>
        </DialogActions>
      </Dialog>

      {/* 浼樺寲寤鸿璇︽儏瀵硅瘽妗?*/}
      <Dialog 
        open={optimizationDialogOpen} 
        onClose={() => setOptimizationDialogOpen(false)}
        maxWidth="md"
        fullWidth
      >
        <DialogTitle>浼樺寲寤鸿璇︽儏</DialogTitle>
        <DialogContent>
          {selectedOptimization && (
            <Box>
              <Typography variant="h5" color="primary" gutterBottom>{selectedOptimization.title}</Typography>
              
              <Grid container spacing={2} sx={{ mb: 3 }}>
                <Grid item xs={12} md={6}>
                  <Typography variant="subtitle1">棰勬湡鏀剁泭:</Typography>
                  <Typography variant="body1" color="success.main" fontWeight="bold">
                    {selectedOptimization.potentialGain}
                  </Typography>
                </Grid>
                <Grid item xs={12} md={6}>
                  <Typography variant="subtitle1">褰卞搷绋嬪害:</Typography>
                  <Chip 
                    label={selectedOptimization.impact} 
                    color={
                      selectedOptimization.impact === 'high' ? 'error' : 
                      selectedOptimization.impact === 'medium' ? 'warning' : 'success'
                    }
                  />
                </Grid>
              </Grid>
              
              <Typography variant="subtitle1" gutterBottom>瀹炴柦鏂规:</Typography>
              <Typography variant="body1" paragraph>
                {selectedOptimization.implementation}
              </Typography>
              
              <Alert severity="info" sx={{ mt: 2 }}>
                <AlertTitle>AI寤鸿</AlertTitle>
                <Typography variant="body2">
                  璇ヤ紭鍖栧缓璁敱AI鍩轰簬鍘嗗彶鏁版嵁銆佽涓氳秼鍔垮拰绔炰簤瀵规墜鍒嗘瀽鐢熸垚銆傞璁″疄鏂藉悗灏嗘樉钁楁彁鍗囩泩鍒╄兘鍔涳紝
                  寤鸿浼樺厛鑰冭檻瀹炴柦銆傚畬鏁村疄鏂借鍒掑凡鐢熸垚锛屽寘鍚缁嗘椂闂磋〃鍜岃祫婧愰渶姹傘€?
                </Typography>
              </Alert>
            </Box>
          )}
        </DialogContent>
        <DialogActions>
          <Button onClick={() => setOptimizationDialogOpen(false)}>鍏抽棴</Button>
          <Button variant="contained" color="primary" onClick={handleApplyOptimization}>
            搴旂敤姝ゅ缓璁?
          </Button>
        </DialogActions>
      </Dialog>

      {/* AI鐩堝埄妯℃嫙鍒嗘瀽瀵硅瘽妗?*/}
      <Dialog 
        open={aiProfitSimulationOpen} 
        onClose={() => setAiProfitSimulationOpen(false)}
        maxWidth="lg"
        fullWidth
      >
        <DialogTitle sx={{ display: 'flex', alignItems: 'center' }}>
          <AIIcon sx={{ mr: 1 }} />
          AI鐩堝埄妯℃嫙鍒嗘瀽
        </DialogTitle>
        <DialogContent>
          {!profitSimulationResults ? (
            <Box sx={{ display: 'flex', flexDirection: 'column', alignItems: 'center', p: 4 }}>
              <CircularProgress size={60} />
              <Typography variant="h6" sx={{ mt: 2 }}>
                AI姝ｅ湪杩涜鐩堝埄鑳藉姏妯℃嫙鍒嗘瀽...
              </Typography>
            </Box>
          ) : (
            <Grid container spacing={3}>
              <Grid item xs={12}>
                <Alert severity="success">
                  <AlertTitle>AI鍒嗘瀽瀹屾垚</AlertTitle>
                  <Typography variant="body1">
                    AI宸插畬鎴愮泩鍒╄兘鍔涙ā鎷熷垎鏋愶紝缁煎悎绛栫暐棰勮鍙彁鍗囧勾搴﹁惀鏀秢profitSimulationResults.combinedStrategy.revenueChange}%锛?
                    鎻愰珮姣涘埄鐜噞profitSimulationResults.combinedStrategy.marginChange}涓櫨鍒嗙偣锛?
                    鎶曡祫鍥炴姤鐜囪揪{profitSimulationResults.combinedStrategy.roi}%銆?
                  </Typography>
                </Alert>
              </Grid>
              
              {/* 棰勬祴鏁堟灉鍥捐〃 */}
              <Grid item xs={12}>
                <Typography variant="h6" gutterBottom>12涓湀鐩堝埄棰勬祴瀵规瘮</Typography>
                <Box height={300}>
                  <ResponsiveContainer width="100%" height="100%">
                    <LineChart data={profitSimulationResults.monthlyProjection}>
                      <CartesianGrid strokeDasharray="3 3" />
                      <XAxis dataKey="month" />
                      <YAxis />
                      <RechartsTooltip />
                      <Legend />
                      <Line type="monotone" dataKey="baseline.profit" name="鍩哄噯鍒╂鼎" stroke="#8884d8" />
                      <Line type="monotone" dataKey="optimized.profit" name="浼樺寲鍚庡埄娑? stroke="#82ca9d" />
                    </LineChart>
                  </ResponsiveContainer>
                </Box>
              </Grid>
            </Grid>
          )}
        </DialogContent>
        <DialogActions>
          <Button onClick={() => setAiProfitSimulationOpen(false)}>鍏抽棴</Button>
          {profitSimulationResults && (
            <Button 
              variant="contained" 
              color="primary" 
              onClick={handleApplyOptimization}
              startIcon={<SaveIcon />}
            >
              搴旂敤AI鎺ㄨ崘绛栫暐
            </Button>
          )}
        </DialogActions>
      </Dialog>

      {/* 绛涢€夊璇濇 */}
      <Dialog open={filterDialogOpen} onClose={handleFilterDialogClose}>
        <DialogTitle>鏁版嵁绛涢€?/DialogTitle>
        <DialogContent>
          <Box sx={{ pt: 2 }}>
            <TextField
              label="鏈€浣庨攢鍞"
              type="number"
              fullWidth
              margin="normal"
            />
            <TextField
              label="鏈€浣庡鎴锋暟"
              type="number"
              fullWidth
              margin="normal"
            />
          </Box>
        </DialogContent>
        <DialogActions>
          <Button onClick={handleFilterDialogClose}>鍙栨秷</Button>
          <Button onClick={handleFilterDialogClose} variant="contained">
            搴旂敤绛涢€?
          </Button>
        </DialogActions>
      </Dialog>

      {/* 鍥捐〃璁剧疆瀵硅瘽妗?*/}
      <Dialog open={settingsDialogOpen} onClose={handleSettingsDialogClose}>
        <DialogTitle>鍥捐〃璁剧疆</DialogTitle>
        <DialogContent>
          <Box sx={{ pt: 2 }}>
            <Typography variant="subtitle1" gutterBottom>
              閿€鍞秼鍔垮浘
            </Typography>
            <FormControl component="fieldset">
              <Stack direction="row" spacing={2}>
                <Chip
                  label="閿€鍞"
                  onClick={() => handleChartSettingChange('salesChart', 'showSales')}
                  color={chartSettings.salesChart.showSales ? 'primary' : 'default'}
                />
                <Chip
                  label="鍒╂鼎"
                  onClick={() => handleChartSettingChange('salesChart', 'showProfit')}
                  color={chartSettings.salesChart.showProfit ? 'primary' : 'default'}
                />
                <Chip
                  label="鎴愭湰"
                  onClick={() => handleChartSettingChange('salesChart', 'showCost')}
                  color={chartSettings.salesChart.showCost ? 'primary' : 'default'}
                />
              </Stack>
            </FormControl>
          </Box>
        </DialogContent>
        <DialogActions>
          <Button onClick={handleSettingsDialogClose}>鍙栨秷</Button>
          <Button onClick={handleSettingsDialogClose} variant="contained">
            淇濆瓨璁剧疆
          </Button>
        </DialogActions>
      </Dialog>

      {/* 鎻愮ず娑堟伅 */}
      <Snackbar
        open={snackbarOpen}
        autoHideDuration={3000}
        onClose={() => setSnackbarOpen(false)}
      >
        <Alert severity="success" onClose={() => setSnackbarOpen(false)}>
          {snackbarMessage}
        </Alert>
      </Snackbar>

      {/* 鍦ㄧ幇鏈塗ab鍐呭鍚庢坊鍔犵泩鍒╄兘鍔涘垎鏋怲ab */}

      {activeTab === 8 && profitabilityData && (
        <Grid container spacing={3}>
          {/* 鎬讳綋鐩堝埄鎸囨爣鍗＄墖 */}
          <Grid item xs={12} md={3}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography color="textSecondary" gutterBottom>姣涘埄鐜?/Typography>
              <Typography variant="h4" fontWeight={700} color="#1976d2">
                {profitabilityData.overview.grossProfitMargin}%
              </Typography>
              <Box display="flex" alignItems="center">
                <TrendingUp color="success" fontSize="small" sx={{ mr: 0.5 }} />
                <Typography variant="body2" color="success.main">杈冧笂骞村闀?2.5%</Typography>
              </Box>
            </Paper>
          </Grid>
          
          <Grid item xs={12} md={3}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography color="textSecondary" gutterBottom>鍑€鍒╃巼</Typography>
              <Typography variant="h4" fontWeight={700} color="#1976d2">
                {profitabilityData.overview.netProfitMargin}%
              </Typography>
              <Box display="flex" alignItems="center">
                <TrendingUp color="success" fontSize="small" sx={{ mr: 0.5 }} />
                <Typography variant="body2" color="success.main">杈冧笂骞村闀?1.8%</Typography>
              </Box>
            </Paper>
          </Grid>
          
          <Grid item xs={12} md={3}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography color="textSecondary" gutterBottom>ROI</Typography>
              <Typography variant="h4" fontWeight={700} color="#1976d2">
                {profitabilityData.overview.roi}%
              </Typography>
              <Box display="flex" alignItems="center">
                <TrendingUp color="success" fontSize="small" sx={{ mr: 0.5 }} />
                <Typography variant="body2" color="success.main">杈冧笂骞村闀?3.2%</Typography>
              </Box>
            </Paper>
          </Grid>
          
          <Grid item xs={12} md={3}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography color="textSecondary" gutterBottom>璧勪骇鍛ㄨ浆鐜?/Typography>
              <Typography variant="h4" fontWeight={700} color="#1976d2">
                {profitabilityData.overview.assetTurnover}
              </Typography>
              <Box display="flex" alignItems="center">
                <TrendingUp color="success" fontSize="small" sx={{ mr: 0.5 }} />
                <Typography variant="body2" color="success.main">杈冧笂骞村闀?0.4</Typography>
              </Box>
            </Paper>
          </Grid>
          
          {/* 鍘嗗彶鐩堝埄瓒嬪娍鍥?*/}
          <Grid item xs={12}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>鍘嗗彶鐩堝埄瓒嬪娍鍒嗘瀽</Typography>
              <Box sx={{ display: 'flex', justifyContent: 'flex-end', mb: 2 }}>
                <Button 
                  variant="contained" 
                  color="primary"
                  startIcon={<AIIcon />}
                  onClick={handleRunProfitSimulation}
                >
                  杩愯AI鐩堝埄妯℃嫙鍒嗘瀽
                </Button>
              </Box>
              <Box height={300}>
                <ResponsiveContainer width="100%" height="100%">
                  <ComposedChart data={profitabilityData.historicalTrend}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="quarter" tickFormatter={(value, index) => `${profitabilityData.historicalTrend[index].year} ${value}`} />
                    <YAxis yAxisId="left" orientation="left" stroke="#8884d8" />
                    <YAxis yAxisId="right" orientation="right" stroke="#82ca9d" />
                    <RechartsTooltip />
                    <Legend />
                    <Bar yAxisId="left" dataKey="revenue" name="钀ユ敹(鍏?" fill="#8884d8" />
                    <Line yAxisId="right" type="monotone" dataKey="margin" name="姣涘埄鐜?%)" stroke="#ff7300" />
                  </ComposedChart>
                </ResponsiveContainer>
              </Box>
            </Paper>
          </Grid>
        </Grid>
      )}

      {/* AI浼樺寲寤鸿Tab */}
      {activeTab === 9 && profitabilityData && (
        <Grid container spacing={3}>
          {/* AI鍒嗘瀽姒傝堪鍗＄墖 */}
          <Grid item xs={12}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>AI绯荤粺鍏ㄩ潰鍒嗘瀽</Typography>
              <Alert severity="info" sx={{ mb: 2 }}>
                <AlertTitle>鏁版嵁鍒嗘瀽瀹屾垚</AlertTitle>
                <Typography variant="body2">
                  AI绯荤粺宸插畬鎴愬浼佷笟杩愯惀鏁版嵁鐨勫叏闈㈠垎鏋愶紝鍩轰簬閿€鍞€佸簱瀛樸€佸鎴枫€佽鍗曘€佺泩鍒╃瓑澶氱淮搴︽暟鎹紝
                  鐢熸垚浜嗕互涓嬩紭鍖栧缓璁€傚缓璁寜浼樺厛绾ф帓搴忥紝瀹炴柦杩欎簺寤鸿棰勮鍙彁鍗囨暣浣撶泩鍒╄兘鍔?5-25%銆?
                </Typography>
              </Alert>
              <Box sx={{ display: 'flex', justifyContent: 'flex-end' }}>
                <Button 
                  variant="contained" 
                  color="primary"
                  startIcon={<AIIcon />}
                  onClick={handleRunProfitSimulation}
                >
                  杩愯AI鐩堝埄妯℃嫙鍒嗘瀽
                </Button>
              </Box>
            </Paper>
          </Grid>

          {/* 灞曠ず鎵€鏈変紭鍖栧缓璁被鍒?*/}
          {profitabilityData.aiOptimizationSuggestions.map((category, index) => (
            <Grid item xs={12} key={index}>
              <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
                <Typography variant="h6" gutterBottom>{category.category}</Typography>
                <Grid container spacing={3}>
                  {category.suggestions.map((suggestion, i) => (
                    <Grid item xs={12} md={4} key={i}>
                      <Card 
                        sx={{ 
                          height: '100%', 
                          cursor: 'pointer', 
                          transition: 'transform 0.3s, box-shadow 0.3s',
                          '&:hover': { transform: 'translateY(-5px)', boxShadow: 5 }
                        }}
                        onClick={() => handleViewOptimizationDetail(suggestion)}
                      >
                        <CardContent>
                          <Box display="flex" justifyContent="space-between" alignItems="center" mb={1}>
                            <Typography variant="h6" color="primary">{suggestion.title}</Typography>
                            <Chip 
                              label={suggestion.impact} 
                              color={
                                suggestion.impact === 'high' ? 'error' : 
                                suggestion.impact === 'medium' ? 'warning' : 'success'
                              }
                              size="small"
                            />
                          </Box>
                          <Typography variant="body2" color="text.secondary" paragraph>
                            {suggestion.implementation}
                          </Typography>
                          <Typography variant="body2" color="success.main" fontWeight="bold">
                            {suggestion.potentialGain}
                          </Typography>
                        </CardContent>
                      </Card>
                    </Grid>
                  ))}
                </Grid>
              </Paper>
            </Grid>
          ))}

          {/* 鏂板AI鍒嗘瀽娲炶 */}
          <Grid item xs={12}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>AI鏁翠綋涓氬姟娲炶</Typography>
              <Grid container spacing={3}>
                <Grid item xs={12} md={4}>
                  <Alert severity="success" sx={{ height: '100%' }}>
                    <AlertTitle>涓氬姟澧為暱鏈轰細</AlertTitle>
                    <Typography variant="body2">
                      鍖荤枟鏈嶅姟鍜屽鏂瑰畾鍒朵笟鍔℃樉绀哄嚭鏈€楂樼殑澧為暱娼滃姏锛屽悓鏃舵瘺鍒╃巼缁存寔鍦ㄥ仴搴锋按骞炽€?
                      寤鸿灏嗘洿澶氳祫婧愬垎閰嶅埌杩欎簺楂樺闀夸笟鍔＄嚎锛岀壒鍒槸绾夸笂娓犻亾锛岄璁″彲甯︽潵瓒呰繃22%鐨勫勾澧為暱鐜囥€?
                    </Typography>
                  </Alert>
                </Grid>
                <Grid item xs={12} md={4}>
                  <Alert severity="warning" sx={{ height: '100%' }}>
                    <AlertTitle>鏁堢巼浼樺寲鏈轰細</AlertTitle>
                    <Typography variant="body2">
                      搴撳瓨绠＄悊鏁堢巼鏈夋樉钁楁彁鍗囩┖闂达紝鐗瑰埆鏄浜庝綆鍛ㄨ浆鑽潗銆傚熀浜嶢I鍒嗘瀽锛?
                      浼樺寲搴撳瓨姘村钩鍜屼緵搴旈摼鍙妭鐪佸勾搴︽垚鏈害8-12%锛屽悓鏃舵彁楂?5%鐨勫簱瀛樺懆杞巼銆?
                    </Typography>
                  </Alert>
                </Grid>
                <Grid item xs={12} md={4}>
                  <Alert severity="info" sx={{ height: '100%' }}>
                    <AlertTitle>绔炰簤浼樺娍鍒嗘瀽</AlertTitle>
                    <Typography variant="body2">
                      鍏徃鍦ㄤ腑鑽ギ鐗囧拰澶勬柟瀹氬埗棰嗗煙鍏锋湁鏄庢樉绔炰簤浼樺娍銆傚缓璁繁鍖栬繖涓€浼樺娍锛?
                      寮€鍙戞洿澶氱壒鑹蹭骇鍝佸拰鏈嶅姟锛屾彁楂樺搧鐗屽樊寮傚寲锛岄璁″彲鎻愬崌瀹㈡埛蹇犺瘹搴﹀拰鏁翠綋鐩堝埄鑳藉姏銆?
                    </Typography>
                  </Alert>
                </Grid>
              </Grid>
            </Paper>
          </Grid>

          {/* 寤鸿瀹炴柦璁″垝 */}
          <Grid item xs={12}>
            <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
              <Typography variant="h6" gutterBottom>AI寤鸿瀹炴柦璁″垝</Typography>
              <TableContainer>
                <Table>
                  <TableHead>
                    <TableRow>
                      <TableCell>浼樺厛绾?/TableCell>
                      <TableCell>寤鸿</TableCell>
                      <TableCell>棰勬湡褰卞搷</TableCell>
                      <TableCell>瀹炴柦闅惧害</TableCell>
                      <TableCell>鏃堕棿妗嗘灦</TableCell>
                      <TableCell>鎿嶄綔</TableCell>
                    </TableRow>
                  </TableHead>
                  <TableBody>
                    <TableRow>
                      <TableCell>1</TableCell>
                      <TableCell>鏅鸿兘閲囪喘绯荤粺瀹炴柦</TableCell>
                      <TableCell>楂?/TableCell>
                      <TableCell>涓?/TableCell>
                      <TableCell>2-3涓湀</TableCell>
                      <TableCell>
                        <Button variant="contained" size="small" onClick={() => handleViewOptimizationDetail(profitabilityData.aiOptimizationSuggestions[1].suggestions[0])}>
                          鏌ョ湅璇︽儏
                        </Button>
                      </TableCell>
                    </TableRow>
                    <TableRow>
                      <TableCell>2</TableCell>
                      <TableCell>澶勬柟瀹氬埗涓氬姟鎵╁睍</TableCell>
                      <TableCell>楂?/TableCell>
                      <TableCell>涓珮</TableCell>
                      <TableCell>3-6涓湀</TableCell>
                      <TableCell>
                        <Button variant="contained" size="small" onClick={() => handleViewOptimizationDetail(profitabilityData.aiOptimizationSuggestions[0].suggestions[0])}>
                          鏌ョ湅璇︽儏
                        </Button>
                      </TableCell>
                    </TableRow>
                    <TableRow>
                      <TableCell>3</TableCell>
                      <TableCell>绾夸笂钀ラ攢娓犻亾浼樺寲</TableCell>
                      <TableCell>楂?/TableCell>
                      <TableCell>涓?/TableCell>
                      <TableCell>1-3涓湀</TableCell>
                      <TableCell>
                        <Button variant="contained" size="small">
                          鏌ョ湅璇︽儏
                        </Button>
                      </TableCell>
                    </TableRow>
                    <TableRow>
                      <TableCell>4</TableCell>
                      <TableCell>鍖荤枟鏈嶅姟椤圭洰浼樺寲</TableCell>
                      <TableCell>涓?/TableCell>
                      <TableCell>涓?/TableCell>
                      <TableCell>2-4涓湀</TableCell>
                      <TableCell>
                        <Button variant="contained" size="small" onClick={() => handleViewOptimizationDetail(profitabilityData.aiOptimizationSuggestions[0].suggestions[1])}>
                          鏌ョ湅璇︽儏
                        </Button>
                      </TableCell>
                    </TableRow>
                  </TableBody>
                </Table>
              </TableContainer>
            </Paper>
          </Grid>
        </Grid>
      )}

      {/* 閿€鍞幆姣斿悓姣斿垎鏋?*/}
      <Grid item xs={12}>
        <Paper sx={{ p: 2, boxShadow: 3, borderRadius: 3, background: 'linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%)' }}>
          <Typography variant="h6" gutterBottom>閿€鍞幆姣斿悓姣斿垎鏋?/Typography>
          <Grid container spacing={3}>
            <Grid item xs={12} md={8}>
              <Box height={300}>
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={[
                    // 浠婂勾鏁版嵁
                    ...salesData.map(item => ({
                      鏈堜唤: item.name,
                      浠婂勾閿€鍞: item.閿€鍞,
                      鍘诲勾閿€鍞: Math.round(item.閿€鍞 * 0.85), // 妯℃嫙鍘诲勾鏁版嵁
                      鍓嶅勾閿€鍞: Math.round(item.閿€鍞 * 0.7),  // 妯℃嫙鍓嶅勾鏁版嵁
                    }))
                  ]}>
                    <CartesianGrid strokeDasharray="3 3" />
                    <XAxis dataKey="鏈堜唤" />
                    <YAxis />
                    <RechartsTooltip formatter={(value) => `楼${value.toLocaleString()}`} />
                    <Legend />
                    <Line type="monotone" dataKey="浠婂勾閿€鍞" stroke="#8884d8" strokeWidth={3} activeDot={{ r: 8 }} />
                    <Line type="monotone" dataKey="鍘诲勾閿€鍞" stroke="#82ca9d" strokeDasharray="3 3" />
                    <Line type="monotone" dataKey="鍓嶅勾閿€鍞" stroke="#ffc658" strokeDasharray="5 5" />
                  </LineChart>
                </ResponsiveContainer>
              </Box>
            </Grid>
            <Grid item xs={12} md={4}>
              <Box sx={{ height: '100%', display: 'flex', flexDirection: 'column', justifyContent: 'space-between' }}>
                <Paper sx={{ p: 2, mb: 2, boxShadow: 2, borderRadius: 2, background: '#f8f9fa' }}>
                  <Typography variant="subtitle1" fontWeight="bold" gutterBottom>鐜瘮鍒嗘瀽 (杈冧笂鏈?</Typography>
                  <Typography variant="body1">
                    閿€鍞: <Chip 
                      label={`${((salesData[11].閿€鍞 / salesData[10].閿€鍞 - 1) * 100).toFixed(1)}%`} 
                      color={(salesData[11].閿€鍞 / salesData[10].閿€鍞 - 1) > 0 ? "success" : "error"} 
                      size="small" 
                      sx={{ ml: 1 }}
                    />
                  </Typography>
                  <Typography variant="body1" mt={1}>
                    鍒╂鼎: <Chip 
                      label={`${((salesData[11].鍒╂鼎 / salesData[10].鍒╂鼎 - 1) * 100).toFixed(1)}%`} 
                      color={(salesData[11].鍒╂鼎 / salesData[10].鍒╂鼎 - 1) > 0 ? "success" : "error"} 
                      size="small" 
                      sx={{ ml: 1 }}
                    />
                  </Typography>
                </Paper>
                <Paper sx={{ p: 2, boxShadow: 2, borderRadius: 2, background: '#f8f9fa' }}>
                  <Typography variant="subtitle1" fontWeight="bold" gutterBottom>鍚屾瘮鍒嗘瀽 (杈冨幓骞村悓鏈?</Typography>
                  <Typography variant="body1">
                    閿€鍞: <Chip 
                      label="+17.6%" 
                      color="success" 
                      size="small" 
                      sx={{ ml: 1 }}
                    />
                  </Typography>
                  <Typography variant="body1" mt={1}>
                    鍒╂鼎: <Chip 
                      label="+21.3%" 
                      color="success" 
                      size="small" 
                      sx={{ ml: 1 }}
                    />
                  </Typography>
                  <Typography variant="body1" mt={1}>
                    瀹㈠崟浠? <Chip 
                      label="+8.5%" 
                      color="success" 
                      size="small" 
                      sx={{ ml: 1 }}
                    />
                  </Typography>
                </Paper>
              </Box>
            </Grid>
          </Grid>
        </Paper>
      </Grid>
    </Box>
  );
}

export default Dashboard; 

